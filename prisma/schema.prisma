datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum LeadStatus {
  HOT
  WARM
  COLD
  CONVERTED
}

enum ClientStatus {
  ACTIVE
  PAUSED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  role      Role     @default(USER)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id             String       @id @default(cuid())
  businessName   String?
  phoneNumberId  String       @unique
  accessToken    String?
  niche          String       @default("LEAD_REPLY_AGENT")
  websiteContent String?
  systemPrompt   String?
  messageLimit   Int          @default(1000)
  status         ClientStatus @default(ACTIVE)
  leads          Lead[]
  chatLogs       ChatLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Lead {
  id          String     @id @default(cuid())
  phone       String
  name        String?
  status      LeadStatus @default(COLD)
  interest    String?
  location    String?
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id])
  chatLogs    ChatLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clientId])
}

model ChatLog {
  id        String   @id @default(cuid())
  sender    String
  message   String
  type      String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([clientId])
}

model ProcessedWebhookMessage {
  id        String   @id
  createdAt DateTime @default(now())
}
