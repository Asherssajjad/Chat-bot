datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum LeadStatus {
  HOT
  WARM
  COLD
  CONVERTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          Role      @default(USER)
  image         String?
  
  // WhatsApp Business Config (Admin Managed)
  phoneId       String?
  wabaId        String?
  accessToken   String?
  webhookSecret String?
  messageLimit  Int       @default(1000)
  autoPause     Boolean   @default(false)
  
  // Bot Configs
  niche         String    @default("LEAD_REPLY_AGENT")
  claudeKey     String?
  whatsappPhone String?
  systemPrompt  String?   @default("You are a helpful assistant.")
  customFlow    String?   // JSON string of custom flow steps
  websiteUrl    String?   // New: Website to scrape for knowledge base
  websiteContent String?  // Cached text content from the website


  // Relationships
  leads         Lead[]
  chatLogs      ChatLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Lead {
  id          String     @id @default(cuid())
  phone       String
  name        String?
  status      LeadStatus @default(COLD)
  interest    String?
  location    String?
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  chatLogs    ChatLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model ChatLog {
  id        String   @id @default(cuid())
  sender    String   // 'BOT' or 'USER'
  message   String
  type      String   // 'FLOW' or 'AI'
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
}
